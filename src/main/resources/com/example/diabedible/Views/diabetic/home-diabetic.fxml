<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.diabedible.controller.HomeDiabeticController">

    <fx:define>
        <Font fx:id="welcomeFont" name="System Bold" size="18.0" />
        <Font fx:id="titleFont" name="System Bold" size="20.0" />
        <Font fx:id="statsTitleFont" name="System Bold" size="16.0" />
        <ToggleGroup fx:id="navGroup"/>
    </fx:define>

    <!-- Barra superiore -->
    <top>
        <HBox spacing="20" style="-fx-padding: 15; -fx-background-color: #34495e;">
            <Text fx:id="welcomeText" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="logoutBtn" maxWidth="Infinity" onAction="#handleLogout"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Logout">
                <HBox.margin>
                    <Insets />
                </HBox.margin>
            </Button>
        </HBox>
    </top>

    <!-- Menu laterale sinistro -->
    <left>
        <VBox fx:id="navigation" prefWidth="200.0"
              style="-fx-background-color: #749bba;">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Separator />
                <ToggleButton fx:id="btnDashboard" toggleGroup="$navGroup"
                              prefHeight="25.0" prefWidth="180.0"
                              selected="true"
                              styleClass="nav-button" text="Dashboard" />
                <Separator />
                <ToggleButton fx:id="btnReadingEntry" toggleGroup="$navGroup"
                              styleClass="nav-button" text="Inserisci Glicemia" />
                <Separator />
                <ToggleButton fx:id="btnReadingList" toggleGroup="$navGroup"
                              styleClass="nav-button" text="Storico Glicemie" />
                <Separator />
                <ToggleButton fx:id="btnTherapy" toggleGroup="$navGroup"
                              styleClass="nav-button" text="La tua terapia" />
                <Separator />
                <ToggleButton fx:id="btnMedicationIntake" toggleGroup="$navGroup"
                              styleClass="nav-button" text="Assunzione farmaci" />
                <Separator />
                <Button fx:id="profilebtn" styleClass="nav-button" text="Il tuo profilo" />
                <Separator />
                <Button text="Registra Sintomo"
                        onAction="#onAddSymptomClicked"
                        styleClass="nav-button" />
            </children>
        </VBox>
    </left>

    <!-- Contenuto centrale -->
    <center>
        <StackPane fx:id="mainStack">
            <children>
                <!-- Dashboard originale -->
                <VBox fx:id="dashboardPane"
                      spacing="20.0"
                      visible="${btnDashboard.selected}"
                      managed="${btnDashboard.selected}">
                    <padding>
                        <Insets topRightBottomLeft="20.0" />
                    </padding>
                    <Text text="Monitoraggio Livello Glicemico" />
                    <LineChart fx:id="bloodSugarChart">
                        <xAxis>
                            <CategoryAxis label="Giorni" />
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Livello Glicemico (mg/dL)"
                                        lowerBound="50.0"
                                        tickUnit="25.0"
                                        upperBound="300.0" />
                        </yAxis>
                    </LineChart>
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <TextField fx:id="readingField" promptText="Inserisci valore glicemia" />
                        <DatePicker fx:id="datePicker" />
                        <ComboBox fx:id="timeSlotComboBox" promptText="Seleziona fascia oraria" />
                        <Button onAction="#handleAddReading" text="Aggiungi" />
                    </HBox>
                </VBox>

                <!-- Inserimento glicemia -->
                <VBox visible="${btnReadingEntry.selected}" managed="${btnReadingEntry.selected}">
                    <fx:include source="reading-entry.fxml"/>
                </VBox>

                <!-- Storico glicemie -->
                <VBox visible="${btnReadingList.selected}" managed="${btnReadingList.selected}">
                    <fx:include source="reading-list.fxml"/>
                </VBox>

                <!-- La tua terapia -->
                <VBox visible="${btnTherapy.selected}" managed="${btnTherapy.selected}">
                    <fx:include source="therapy-patient.fxml"/>
                </VBox>

                <!-- Assunzione farmaci -->
                <VBox visible="${btnMedicationIntake.selected}" managed="${btnMedicationIntake.selected}">
                    <fx:include source="medication-intake.fxml"/>
                </VBox>
            </children>
        </StackPane>
    </center>

    <!-- Colonna destra -->
    <right>
        <VBox fx:id="Assunzioni" prefWidth="250.0" spacing="15.0"
              style="-fx-background-color: #ecf0f1; -fx-background-radius: 10;">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Text text="Task giornaliere" />
                <Separator />
                <VBox fx:id="checklistContainer" spacing="10" />
            </children>
        </VBox>
    </right>
</BorderPane>
