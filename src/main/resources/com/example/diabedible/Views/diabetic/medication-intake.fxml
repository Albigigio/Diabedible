<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.diabedible.controller.MedicationIntakeController"
      spacing="10">

    <Label text="Registra assunzione farmaco" />

    <TextField fx:id="medNameField" promptText="Nome farmaco" />
    <TextField fx:id="doseField" promptText="Dose" />

    <Button text="Registra" onAction="#onRegister" />
</VBox>
